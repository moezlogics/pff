# Your Medusa backend, should be updated to where you are hosting your server. Remember to update CORS settings for your server. See – https://docs.medusajs.com/learn/configurations/medusa-config#httpstorecors
MEDUSA_BACKEND_URL=http://localhost:8012
NEXT_PUBLIC_MEDUSA_BACKEND_URL=https://api.pff.org.pk
REVALIDATE_SECRET=fff19f20818d11902e43a8cbb1642db8a3bbeb6c950f098ea28603506fb12a90
# Your publishable key that can be attached to sales channels. See - https://docs.medusajs.com/resources/storefront-development/publishable-api-keys
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_d8b0cf99f2389d06cf46ce2e851b76074cd89b3e304ab25eacac4a988335fd87

# Your store URL, should be updated to where you are hosting your storefront.
NEXT_PUBLIC_BASE_URL=https://pff.org.pk

# Your preferred default region. When middleware cannot determine the user region from the "x-vercel-country" header, the default region will be used. ISO-2 lowercase format.
NEXT_PUBLIC_DEFAULT_REGION=pk

# Your Next.js revalidation secret. See – https://nextjs.org/docs/app/building-your-application/data-fetching/fetching-caching-and-revalidating#on-demand-revalidation
REVALIDATE_SECRET=d19e35d44b1a0da79966c98ae2e7ccad80c684f6cc6d370ada041f5181607df3

# ---- Google Analytics (GA4) ----
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# ---- Meilisearch ----
# All search traffic flows through the same-origin proxy at /api/search.
# The proxy injects the server-side key on each request, so the browser
# bundle never ships secret credentials and port 7700 stays private.
#
# Leave NEXT_PUBLIC_MEILISEARCH_HOST empty (or unset) — the components
# default to "/api/search" when it's blank. Only set it as a legacy
# override if you really want direct browser-to-Meilisearch traffic.
NEXT_PUBLIC_MEILISEARCH_HOST=
NEXT_PUBLIC_MEILISEARCH_SEARCH_KEY=
NEXT_PUBLIC_MEILISEARCH_PRODUCT_INDEX_NAME=products

# Server-side only — never exposed to the browser. The proxy reads
# these to talk to the Meilisearch server over the local network.
MEILISEARCH_INTERNAL_HOST=http://127.0.0.1:7700
MEILISEARCH_SEARCH_KEY=Multanpakistan1!Multanpakistan1!

# ---- Google OAuth sign-in redirect (frontend callback) ----
NEXT_PUBLIC_GOOGLE_CALLBACK_URL=https://pff.org.pk/auth/google/callback

# ---- Self-hosted CDN ----
NEXT_PUBLIC_CDN_URL=https://cdn.pff.org.pk
CDN_PUBLIC_URL=https://cdn.pff.org.pk

# ---- Default Sales Channel ----
NEXT_PUBLIC_MEDUSA_SALES_CHANNEL_ID=sc_01KQ25GHDC4NEK7JQSWH1GV3QG
